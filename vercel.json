{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "rewrites": [
    {
      "source": "/setup",
      "destination": "/api/setup.php"
    },
    {
      "source": "/auth.php",
      "destination": "/api/auth.php"
    },
    {
      "source": "/api.php",
      "destination": "/api/api.php"
    }
  ]
}
