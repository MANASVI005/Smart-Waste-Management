{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/setup",
      "dest": "/api/setup.php"
    },
    {
      "src": "/auth.php",
      "dest": "/api/auth.php"
    },
    {
      "src": "/api.php",
      "dest": "/api/api.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
